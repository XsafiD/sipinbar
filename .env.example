# ============================================================
# .env.example — Template Environment Variables
# ============================================================
# Copy file ini ke `.env` dan sesuaikan nilainya:
#   cp .env.example .env
#
# PENTING: File `.env` JANGAN di-commit ke git (sudah di .gitignore)
# ============================================================

# Secret key untuk signing session cookie & CSRF token
# Generate baru: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ubah-secret-key-ini-dengan-string-acak-yang-panjang

# Path file database SQLite (relative terhadap root project)
DATABASE_PATH=database/sipinbar.db

# Folder upload foto barang
UPLOAD_FOLDER=static/img
MAX_CONTENT_LENGTH=5242880

# Konfigurasi sesi
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
